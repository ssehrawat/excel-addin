{
  "name": "chart_with_selection",
  "description": "Chart keyword with selection triggers chart_inserts event",
  "prompt": "Create a chart of this data",
  "provider": "mock",
  "workbook": {
    "sheets": {
      "Sales": { "A1": "Month", "B1": "Revenue", "A2": "Jan", "B2": 10000 }
    },
    "activeSheet": "Sales",
    "selectedRange": "Sales!A1:B2"
  },
  "expectedEventTypes": ["message_start", "message_done", "chart_inserts", "done"],
  "expectedMutations": {
    "chartInserts": [{ "chartType": "columnClustered" }]
  },
  "expectedToolRounds": 0
}
