# =============================================================================
# Workbook Copilot — Backend Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys:
#
#   cp .env.example .env
#
# All variables use the COPILOT_ prefix (handled by pydantic-settings).
# Restart the backend after making changes (settings are cached at startup).
# =============================================================================

# ---------------------------------------------------------------------------
# LLM Providers
# ---------------------------------------------------------------------------

# Mock provider — returns canned responses, no external API calls.
# Enabled by default so you can run immediately without API keys.
COPILOT_MOCK_PROVIDER_ENABLED=true

# OpenAI
COPILOT_OPENAI_API_KEY=
COPILOT_OPENAI_MODEL=gpt-4o-mini
COPILOT_OPENAI_TEMPERATURE=0.2

# Anthropic
COPILOT_ANTHROPIC_API_KEY=
COPILOT_ANTHROPIC_MODEL=claude-3-5-sonnet-20240620
COPILOT_ANTHROPIC_TEMPERATURE=0.2

# ---------------------------------------------------------------------------
# Timeouts
# ---------------------------------------------------------------------------

# Overall request timeout for LLM calls (seconds).
COPILOT_REQUEST_TIMEOUT_SECONDS=120

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
COPILOT_LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# MCP (Model Context Protocol) Servers
# ---------------------------------------------------------------------------

# Path to MCP server config file (relative to backend/app/ or absolute).
COPILOT_MCP_CONFIG_PATH=data/mcp_servers.json

# Timeout for individual MCP tool invocations (seconds).
COPILOT_MCP_REQUEST_TIMEOUT_SECONDS=15
